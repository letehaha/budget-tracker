# ────────────────────────────────────────────────────────────────────────
# Budget Tracker – Self-host production env example
#
# Copy this file to .env in this folder, then fill in the REQUIRED section.
# Boot the stack from here:
#
#   cd self-hosting
#   cp .env.example .env
#   docker compose up -d
#
# This file stays ON THE VPS. Compose auto-loads it as ./.env beside the compose
# file – for interpolation into the frontend `environment:` block and the
# port/tag settings, and via `env_file:` for the backend container's runtime
# env. It is NEVER copied into a Docker image – DB password and auth secrets
# stay out of pushed image layers. Do NOT commit .env to git.
# ────────────────────────────────────────────────────────────────────────


# ========================================================================
# REQUIRED – the stack will not boot without these
# ========================================================================

NODE_ENV=production

# --- App URL ---------------------------------------------------------------
# The exact URL you open the app at in the browser – auth cookies and CORS
# are bound to it. The default matches HTTP_PORT below, so a localhost trial
# works as-is. For a real deployment set your public URL instead (e.g.
# https://budget.example.com); the API stays on this same origin under /api.
# Keep both variables identical.
BETTER_AUTH_URL=http://localhost:8080
AUTH_ORIGIN=http://localhost:8080

# --- Auth secrets – generate each with: openssl rand -base64 32 ----------
# The backend refuses to start while any of these is still __REPLACE_ME__.
APPLICATION_JWT_SECRET=__REPLACE_ME__
APP_SESSION_ID_SECRET=__REPLACE_ME__
BETTER_AUTH_SECRET=__REPLACE_ME__

# --- Database ------------------------------------------------------------
APPLICATION_DB_HOST=db
APPLICATION_DB_PORT=5432
APPLICATION_DB_USERNAME=budget_tracker
APPLICATION_DB_PASSWORD=__REPLACE_ME__
APPLICATION_DB_DATABASE=budget_tracker
APPLICATION_DB_DIALECT=postgres

# --- Redis ---------------------------------------------------------------
APPLICATION_REDIS_HOST=redis

# --- Backend bind --------------------------------------------------------
# APPLICATION_PORT is read by the backend at runtime AND by compose (frontend
# proxy target + healthcheck). Change both places by changing it here.
APPLICATION_HOST=0.0.0.0
APPLICATION_PORT=8081


# ========================================================================
# COMPOSE-LEVEL (optional) – only read by docker compose, defaults shown
# ========================================================================

# Host port the app is published on (frontend container -> :80).
# HTTP_PORT=8080

# Image tag to pull for backend + frontend.
# IMAGE_TAG=latest

# Postgres / Redis are not published to the host by default. To reach them
# from the host (psql, redis-cli, backups), uncomment the matching `ports:`
# line in docker-compose.yml; these variables then pick the host ports.
# DB_HOST_PORT=5432
# REDIS_HOST_PORT=6379


# ========================================================================
# TRAEFIK OVERLAY ONLY – ignored unless you add docker-compose.traefik.yml
# ========================================================================

# Domain Traefik serves the app on, plus the ACME contact for Let's Encrypt.
# SELFHOST_FRONTEND_DOMAIN=budget.example.com
# LETSENCRYPT_EMAIL=you@example.com

# Split-domain mode only: serve the API on its own host. Requires uncommenting
# the backend labels block in docker-compose.traefik.yml and setting
# API_HTTP=https://api.example.com below.
# SELFHOST_API_DOMAIN=api.example.com


# ========================================================================
# OPTIONAL FEATURES – backend runtime; each stays off until set
# ========================================================================

# --- Email (transactional / verification). Without RESEND_API_KEY email
# verification is disabled and users can register with any address. ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev

# --- OAuth providers (both pairs are independent – set one or both). ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Bank linking via Enable Banking. Must be https://<origin>/bank-callback ---
# ENABLE_BANKING_REDIRECT_URL=https://budget.example.com/bank-callback

# --- Investments / market data (set one or more) ---
# POLYGON_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# FMP_API_KEY=
# COINGECKO_API_KEY=
# CRYPTO_PRICES_SYNC_INTERVAL_MINUTES=15 # Crypto price sync cadence in minutes (integer 1–59). Default: 15.

# --- Currency rates: APILayer paid fallback. The bundled currency-rates-api
# sidecar covers the common case; APILayer is only needed for
# currencies outside its support list. ---
# API_LAYER_API_KEYS=

# --- AI transaction categorisation (set one) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=

# --- logo.dev secret key for payee brand-logo search (server-side only) ---
# LOGO_DEV_SECRET_KEY=

# --- Admins (comma-separated usernames; grants admin API access) ---
# ADMIN_USERS=

# --- Passkeys / WebAuthn ---
# AUTH_RP_ID defaults to "localhost"; set to your bare domain (no scheme)
# for passkey support. Must be a registrable suffix of AUTH_ORIGIN.
# AUTH_RP_ID=example.com
# AUTH_RP_NAME=Budget Tracker

# --- Extra CORS origins (comma-separated, beyond AUTH_ORIGIN) ---
# ALLOWED_ORIGINS=

# --- Backend observability ---
# SENTRY_DSN=


# ========================================================================
# FRONTEND (optional, runtime) – interpolated into the frontend container's
# `environment:` block in docker-compose.yml. Change + `up -d`, no rebuild.
# ========================================================================

# Analytics / error tracking (frontend-facing public values).
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=
# VITE_SENTRY_DSN=
# VITE_SENTRY_RELEASE=

# Brand logos for subscriptions, banks, and stock tickers (logo.dev). Without
# a token the app falls back to initials / asset-class icons. Free token at
# https://www.logo.dev.
# VITE_LOGO_DEV_TOKEN=

# MCP base URL advertised to MCP clients (defaults to same-origin).
# MCP_BASE_URL=

# Point the SPA at a separate API origin (leave unset for same-origin mode).
# API_HTTP=https://api.example.com
# API_VER=/api/v1

# Extra CSP allow-list hosts. CSP_EXTRA_CONNECT and CSP_EXTRA_FORM_ACTION
# default to API_HTTP; set them only if you serve from multiple domains.
# CSP_EXTRA_CONNECT=
# CSP_EXTRA_FORM_ACTION=
#
# CSP_EXTRA_ANALYTICS defaults to VITE_POSTHOG_HOST alone. If you set
# VITE_SENTRY_DSN above, set this too — the Sentry ingest host can't be derived
# from the DSN, and unset means connect-src blocks every error report.
# CSP_EXTRA_ANALYTICS=


# ========================================================================
# BUILD-FROM-SOURCE ONLY – used with docker-compose.build.yml (--build)
# ========================================================================

# Sentry source-map upload during the frontend image build (optional).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=
