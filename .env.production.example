# ────────────────────────────────────────────────────────────────────────
# Budget Tracker — Self-host production env example
#
# Copy this file to .env.production at the repo root, then fill in the
# REQUIRED section.
#
# This file stays ON THE VPS. The compose file reads it via `--env-file`
# (build-time interpolation for VITE_* args) and `env_file:` (runtime
# backend env). It is NEVER copied into a Docker image — DB password and
# auth secrets stay out of pushed image layers.
#
# Frontend (VITE_*) values are inlined at Docker BUILD time, so any change
# to them needs `docker compose build frontend` afterwards.
# ────────────────────────────────────────────────────────────────────────

# === REQUIRED — boot fails without these ================================

NODE_ENV=production

# --- Domains (split-subdomain layout: app.example.com + api.example.com) ---
# These drive Traefik routing, OAuth callbacks, and CSP whitelists.
SELFHOST_FRONTEND_DOMAIN=app.example.com
SELFHOST_API_DOMAIN=api.example.com
LETSENCRYPT_EMAIL=you@example.com

# --- Backend public URL + frontend origin ---
# These two MUST match SELFHOST_API_DOMAIN / SELFHOST_FRONTEND_DOMAIN.
BETTER_AUTH_URL=https://api.example.com
AUTH_ORIGIN=https://app.example.com

# --- Auth secrets — generate with: openssl rand -base64 32 ---
APPLICATION_JWT_SECRET=__REPLACE_ME__
APP_SESSION_ID_SECRET=__REPLACE_ME__
BETTER_AUTH_SECRET=__REPLACE_ME__

# --- Database ---
APPLICATION_DB_HOST=db
APPLICATION_DB_PORT=5432
APPLICATION_DB_USERNAME=budget_tracker
APPLICATION_DB_PASSWORD=__REPLACE_ME__
APPLICATION_DB_DATABASE=budget_tracker
APPLICATION_DB_DIALECT=postgres

# --- Redis ---
APPLICATION_REDIS_HOST=redis

# --- Backend bind ---
APPLICATION_HOST=0.0.0.0
APPLICATION_PORT=8081

# --- Frontend build-time (inlined into the JS bundle) ---
VITE_APP_API_HTTP=https://api.example.com
VITE_APP_API_VER=/api/v1

# === OPTIONAL — features off until set ==================================

# --- Email (transactional / verification). Without RESEND_API_KEY email
# verification is disabled and users can register with any address. ---
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=onboarding@resend.dev

# --- OAuth providers (both pairs are independent — set one or both). ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Bank linking via Enable Banking. Must be https://<frontend>/bank-callback ---
# ENABLE_BANKING_REDIRECT_URL=https://app.example.com/bank-callback

# --- Investments / market data (set one or more) ---
# POLYGON_API_KEY=
# ALPHA_VANTAGE_API_KEY=
# FMP_API_KEY=
# COINGECKO_API_KEY=

# --- Currency rates: APILayer paid fallback. The bundled currency-rates-api
# + frankfurter sidecars cover the common case; APILayer is only needed for
# currencies outside their support list. ---
# API_LAYER_API_KEYS=

# --- AI transaction categorisation (set one) ---
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=

# --- Observability (all optional) ---
# SENTRY_DSN=
# VITE_SENTRY_DSN=
# POSTHOG_KEY=
# POSTHOG_HOST=
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=

# --- Admins (comma-separated usernames; grants admin API access) ---
# ADMIN_USERS=

# --- Passkeys / WebAuthn ---
# AUTH_RP_ID defaults to "localhost"; set to your bare domain (no scheme)
# for passkey support. Must be a registrable suffix of AUTH_ORIGIN.
# AUTH_RP_ID=example.com
# AUTH_RP_NAME=Budget Tracker

# --- Extra CORS origins (comma-separated, beyond AUTH_ORIGIN) ---
# ALLOWED_ORIGINS=

# === ADVANCED ===========================================================

# Override CSP connect-src / form-action whitelists. Defaults derive from
# VITE_APP_API_HTTP at frontend Docker build time, which is correct for
# split-subdomain self-hosters. Set explicitly if you serve from multiple
# domains or need additional third-party origins.
# CSP_EXTRA_CONNECT=https://api.example.com
# CSP_EXTRA_FORM_ACTION=https://api.example.com

# Extra CSP connect-src hosts for PostHog / Sentry. Leave empty if you
# don't run analytics — keeps the CSP minimal.
# CSP_EXTRA_ANALYTICS=https://*.i.posthog.com https://*.sentry.io

# Disable all background exchange-rate fetch jobs (air-gapped testing only)
# OFFLINE_MODE=false

# Disable Yahoo Finance as an investments data source
# YAHOO_FINANCE_ENABLED=true

# Backend SQL query logging
# DB_QUERY_LOGGING=false

# --- Port overrides (set if these are taken on the host) ---
# Compose binds Postgres + Redis to 127.0.0.1 (admin via SSH tunnel) and
# Traefik to 0.0.0.0. If the host already runs Postgres on 5432, Redis on
# 6379, or anything on 80/443, the stack fails to start with
# "address already in use". Override here.
# DB_HOST_PORT=5432
# REDIS_HOST_PORT=6379
# TRAEFIK_HTTP_PORT=80
# TRAEFIK_HTTPS_PORT=443
