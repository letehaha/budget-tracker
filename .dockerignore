# Dependencies
node_modules
packages/*/node_modules

# Build artifacts
dist
build
.next

# IDE
.vscode
.idea
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Git
.git
.gitignore

# Environment
# Keep secret env files out of the build context. The self-hosting kit's
# .env sits next to the compose file inside self-hosting/, which the backend
# Dockerfile copies wholesale — so it must never be baked into an image layer.
.env
.env.local
.env.*.local
.env.production
self-hosting/.env

# Logs
*.log
npm-debug.log*

# Testing
coverage
.nyc_output

# Docker
.dockerignore
Dockerfile
docker-compose*.yml
